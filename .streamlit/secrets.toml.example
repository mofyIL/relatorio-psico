[app]
base_url = "https://SEU-APP.streamlit.app"
admin_password = "TROQUE-POR-UMA-SENHA-FORTE"
min_group_size = 5
report_version = "2.0"
operator_name = "RAZAO SOCIAL DA PRESTADORA"
privacy_contact = "privacidade@example.com"
retention_policy = "Descreva o prazo e o critério de retenção definidos no contrato e na política de privacidade."

# O nome desta seção foi mantido por compatibilidade. A planilha agora recebe
# as respostas diretamente do formulário anônimo do Streamlit.
[google_forms]
spreadsheet_id = "ID_DA_PLANILHA_GOOGLE"

[gcp_service_account]
type = "service_account"
project_id = "SEU_PROJETO"
private_key_id = "ID_DA_CHAVE"
private_key = "-----BEGIN PRIVATE KEY-----\nSUA_CHAVE\n-----END PRIVATE KEY-----\n"
client_email = "CONTA_DE_SERVICO@SEU_PROJETO.iam.gserviceaccount.com"
client_id = "ID_DO_CLIENTE"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "URL_DO_CERTIFICADO"
universe_domain = "googleapis.com"

[google_drive_oauth]
client_id = "CLIENT_ID.apps.googleusercontent.com"
client_secret = "CLIENT_SECRET"
refresh_token = "REFRESH_TOKEN"
token_uri = "https://oauth2.googleapis.com/token"

[drive]
folder_id = "ID_DA_PASTA_DE_RELATORIOS"

# Se o pagamento Pix não for usado, esta seção pode ser omitida.
[pix]
key = "CHAVE_PIX"
receiver_name = "NOME DO RECEBEDOR"
receiver_city = "CIDADE"
description = "MAPEAMENTO PSICOSSOCIAL"
payment_contact = "financeiro@example.com"
